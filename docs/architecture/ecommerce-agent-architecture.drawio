        <mxCell id="p3-subtitle" value="Choose by responsibility and lifecycle, not by convenience" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontColor=#52656A;" vertex="1" parent="1"><mxGeometry x="42" y="62" width="1600" height="28" as="geometry"/></mxCell>

