        <mxCell id="p3-skill" value="&lt;b&gt;SKILL IN SOURCE&lt;/b&gt;&lt;br&gt;ecommerce_agent/skills/*.md&lt;br&gt;progressive disclosure&lt;br&gt;list_skills → load_skill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDEFF3;strokeColor=#1B6B8F;strokeWidth=2;fontColor=#0B2026;fontSize=14;" vertex="1" parent="1"><mxGeometry x="380" y="690" width="300" height="115" as="geometry"/></mxCell>
        <mxCell id="p3-volume-future" value="&lt;b&gt;OPTIONAL VOLUME PROVIDER&lt;/b&gt;&lt;br&gt;only for independent publishing lifecycle&lt;br&gt;read-only • pinned version • rollback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#87999D;dashed=1;strokeWidth=2;fontColor=#0B2026;fontSize=13;" vertex="1" parent="1"><mxGeometry x="210" y="900" width="310" height="105" as="geometry"/></mxCell>

        <mxCell id="p3-q-operational" value="Is it raw/generated business data or a document?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#EEEDE9;strokeColor=#0B2026;strokeWidth=2;fontColor=#0B2026;fontSize=15;" vertex="1" parent="1"><mxGeometry x="750" y="470" width="360" height="125" as="geometry"/></mxCell>
