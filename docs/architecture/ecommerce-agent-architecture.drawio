        <mxCell id="p3-uc-func" value="&lt;b&gt;UNITY CATALOG FUNCTION&lt;/b&gt;&lt;br&gt;SQL for governed data queries&lt;br&gt;Python for sandboxed deterministic policy logic&lt;br&gt;typed contract + explicit grants" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B2026;strokeColor=#FF3621;strokeWidth=3;fontColor=#FFFFFF;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1470" y="680" width="290" height="135" as="geometry"/></mxCell>
