        <mxCell id="p3-q-behavior" value="Is it agent instruction or operational data?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#EEEDE9;strokeColor=#0B2026;strokeWidth=2;fontColor=#0B2026;fontSize=15;" vertex="1" parent="1"><mxGeometry x="650" y="265" width="420" height="135" as="geometry"/></mxCell>
